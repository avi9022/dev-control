  "type": "module",
  "main": "dist-electron/electron/main",
  "scripts": {
    "dev": "npm-run-all --parallel dev:react dev:electron",
    "dev:react": "vite",
    "dev:electron": "nodemon --watch src/electron --exec \"npm run start:electron\" --signal SIGTERM",
    "start:electron": "npm run transpile:electron && cross-env NODE_ENV=development electron .",
    "transpile:electron": "tsc --project src/electron/tsconfig.json",
